# ============================================================
#  JDTech — Git Ignore
#  PURPOSE: Tells Git which files to NEVER commit to the repo.
#
#  BEGINNER TIP:
#  Always add sensitive files (passwords, API keys) here.
#  Once committed, secrets in Git history are very hard to remove.
# ============================================================

# ── Sensitive Files (NEVER commit these) ──────────────────
.env
*.env.local
*.env.production

# ── Uploads (user-generated content, not source code) ─────
uploads/profile/*
uploads/products/*
uploads/documents/*
!uploads/profile/.gitkeep
!uploads/products/.gitkeep
!uploads/documents/.gitkeep

# ── Logs ──────────────────────────────────────────────────
logs/*.log
!logs/.gitkeep

# ── PHP Composer ──────────────────────────────────────────
vendor/
composer.lock

# ── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor Files ────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Temporary Files ───────────────────────────────────────
*.tmp
*.bak
*.swp
*~
