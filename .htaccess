# ============================================================
#  JDTech — Apache .htaccess
#  PURPOSE: Controls how Apache web server handles requests.
#
#  KEY RULES HERE:
#  1. Block direct access to sensitive folders/files
#  2. Redirect all 404 errors to our custom 404.php
#  3. Force HTTPS in production (optional, uncomment below)
#  4. Add security headers
#
#  NOTE: Rename this file to ".htaccess" (with the dot)
#        for it to take effect. The dot is intentional!
# ============================================================

Options -Indexes

# ── Security: Block access to sensitive files ─────────────
<FilesMatch "\.(env|log|sql|md|json|lock|gitignore)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Block access to sensitive folders ─────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes/ folder
    RewriteRule ^includes/.*$ - [F,L]

    # Block direct access to database/ folder
    RewriteRule ^database/.*$ - [F,L]

    # Block direct access to logs/ folder
    RewriteRule ^logs/.*$     - [F,L]

    # Block direct access to vendor/ folder
    RewriteRule ^vendor/.*$   - [F,L]
</IfModule>

# ── Custom error pages ────────────────────────────────────
ErrorDocument 404 /jdtech/404.php
ErrorDocument 403 /jdtech/404.php

# ── Security Headers ──────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Block clickjacking (prevents your site being in an iframe)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Enable XSS Protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Strict referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Force HTTPS (uncomment for production) ────────────────
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ── Compression (faster page loads) ──────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── Browser Caching for static assets ────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css              "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png             "access plus 1 year"
    ExpiresByType image/jpeg            "access plus 1 year"
    ExpiresByType image/gif             "access plus 1 year"
    ExpiresByType image/webp            "access plus 1 year"
</IfModule>
